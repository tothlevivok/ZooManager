<UserControl x:Class="ZooManager.View.AnimalDisplay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:ZooManager.View"
             mc:Ignorable="d"
             d:DesignHeight="50" d:DesignWidth="600">
    <Grid Background="WhiteSmoke">
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <Label Grid.Column="0" Content="{Binding Name}"/>
        <Label Grid.Column="1" Content="{Binding Species}"/>
        <CheckBox Grid.Column="2" IsEnabled="False" IsChecked="{Binding IsEndangered}" Content="Veszelyeztetett"/>
    </Grid>
</UserControl>
